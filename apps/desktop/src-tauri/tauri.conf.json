{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSS Capacity Runner",
  "version": "0.0.0",
  "identifier": "dev.oss-capacity.runner",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OSS Capacity Runner",
        "width": 1100,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
